{
  "permissions": {
    "allow": [
      "Bash(bash ~/.dotfiles/scripts/*)"
    ]
  },
  "env": {
    "IS_SANDBOX": "true"
  },
  "model": "sonnet[1m]",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.sh"
  },
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "stable",
  "tui": "default",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "it2attention once"
          },
          {
            "type": "command",
            "command": "rm -f /tmp/claude_tmux_status"
          }
        ]
      }
    ]
  }
}
